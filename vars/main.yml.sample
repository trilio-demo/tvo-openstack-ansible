---
# ── OpenStack auth ────────────────────────────────────────────────────────────
os_cloud: openstack                          # cloud name in clouds.yaml
os_project_id: <your-project-uuid>           # openstack project show <name> -f value -c id
os_project_name: <your-project-name>

# ── Resource naming ───────────────────────────────────────────────────────────
# demo_prefix: prepended to all managed resources (VMs, volumes, ports,
#   workloads, snapshots).  Pick something short and unique to you, e.g. alice.
demo_prefix: <your-prefix>

# demo_keypair: keypair injected into all VMs.  Defaults to <prefix>-ansible-key.
#   Override if you want to reuse an existing keypair with a different name.
demo_keypair: "{{ demo_prefix }}-ansible-key"

# demo_sg: security group applied to all VMs and ports.
#   Must already exist — not created by these playbooks.
demo_sg: <your-sg-name>

# ── Trilio workload definitions ───────────────────────────────────────────────
# instance_names: VM names as they exist in your OpenStack project.
#
# backup_target_type: the Type ID reported by:
#   openstack workloadmgr backup target list
# Set each workload to the appropriate S3 or NFS target type ID for your environment.
#
# demo_tag: used to run a single demo scenario:
#   ansible-playbook playbooks/setup_trilio.yml -e target_demo=ocr

trilio_workloads:
  - name: "{{ demo_prefix }}-ocr-workload"
    description: "Prepared for One-Click Restore (OCR) demo"
    demo_tag: ocr
    instance_names:
      - "{{ demo_prefix }}-ocr-vm"
    backup_target_type: <s3-backup-target-type-id>
    snapshot_name: "{{ demo_prefix }}-ocr-snapshot"

  - name: "{{ demo_prefix }}-ir-workload"
    description: "Prepared for In-Place Restore (IR) demo"
    demo_tag: ir
    instance_names:
      - "{{ demo_prefix }}-ir-vm1"
      - "{{ demo_prefix }}-ir-vm2"
    backup_target_type: <nfs-backup-target-type-id>
    snapshot_name: "{{ demo_prefix }}-ir-snapshot"

  - name: "{{ demo_prefix }}-sel-workload"
    description: "Prepared for Selective Restore (SEL) demo"
    demo_tag: sel
    instance_names:
      - "{{ demo_prefix }}-sel-vm1"
      - "{{ demo_prefix }}-sel-vm2"
    backup_target_type: <nfs-backup-target-type-id>
    snapshot_name: "{{ demo_prefix }}-sel-snapshot"

  - name: "{{ demo_prefix }}-db-workload"
    description: "Prepared for DB backup demo"
    demo_tag: db
    instance_names:
      - "{{ demo_prefix }}-db1-vm"
      - "{{ demo_prefix }}-db2-vm"
    backup_target_type: <s3-backup-target-type-id>
    snapshot_name: "{{ demo_prefix }}-db-snapshot"
