---
# ── OpenStack auth ────────────────────────────────────────────────────────────
os_cloud: openstack                          # cloud name in clouds.yaml
os_project_id: <your-project-uuid>           # openstack project show <name> -f value -c id
os_project_name: <your-project-name>

# ── Resource naming ───────────────────────────────────────────────────────────
# demo_prefix: prepended to all managed resources.  Default is empty —
#   resources are named firewall-vm, webapp-lb, database-primary, etc.
#   Set to e.g. "mylab-" (include trailing dash) to namespace them.
# demo_prefix: ""

# demo_keypair: keypair injected into all VMs.  Independent of demo_prefix.
# demo_keypair: my-keypair-name

# demo_sg: security group applied to all VMs and ports.
# demo_sg: my-security-group

# ── Trilio workload definitions ───────────────────────────────────────────────
# instance_names: VM names as they exist in your OpenStack project.
#
# backup_target_type: the Type ID reported by:
#   openstack workloadmgr backup target list
# Set each workload to the appropriate S3 or NFS target type ID for your environment.
#
# demo_tag: used to run a single demo scenario:
#   ansible-playbook playbooks/setup_trilio.yml --tags fw

trilio_workloads:
  - name: firewall-workload
    description: "Virtual firewall appliance — One-Click Restore demo"
    demo_tag: fw
    instance_names:
      - firewall-vm
    backup_target_type: <s3-backup-target-type-id>
    snapshot_name: firewall-snapshot

  - name: webapp-workload
    description: "3-tier web application — Selective and In-Place Restore demos"
    demo_tag: app
    instance_names:
      - webapp-lb
      - webapp-fe
      - webapp-be
    backup_target_type: <nfs-backup-target-type-id>
    snapshot_name: webapp-snapshot

  - name: database-workload
    description: "Primary/replica database — crash-consistent DB backup demo"
    demo_tag: pg
    instance_names:
      - database-primary
      - database-replica
    backup_target_type: <s3-backup-target-type-id>
    snapshot_name: database-snapshot
